FROM node:20-bookworm-slim AS node

FROM python:3.11-slim-bookworm

WORKDIR /opt/iandsec-uc

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PNPM_HOME=/root/.local/share/pnpm

ENV PATH=${PNPM_HOME}:${PATH}

# 复制官方 Node 20 运行时，避免通过 apt/nodesource 下载 Node。
COPY --from=node /usr/local /usr/local

# 启用 pnpm。开发镜像不安装 apt 包，避免构建卡在 Debian 包下载。
RUN corepack enable \
    && corepack prepare pnpm@9.15.9 --activate \
    && pnpm config set registry https://registry.npmmirror.com

# 复制依赖文件并安装后端依赖。源码运行时通过 compose bind mount 覆盖。
COPY requirements.txt .
RUN pip install -r requirements.txt -i https://pypi.tuna.tsinghua.edu.cn/simple

# 预装前端依赖，运行时仍会基于挂载源码校验 pnpm install。
COPY web/package.json web/pnpm-lock.yaml ./web/
RUN cd web && pnpm install --frozen-lockfile

ENV LANG=C.UTF-8
EXPOSE 9999 3100

ENTRYPOINT [ "sh", "deploy/entrypoint-dev.sh" ]
